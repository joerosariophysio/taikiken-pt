# =========================================================================
# .env.example — copiar para .env.local antes de rodar o site
# Nunca commitar .env.local ou .env.production.
# =========================================================================

# -------------------------------------------------------------------------
# Site config (público)
# -------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME="Nome do Site"
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR

# -------------------------------------------------------------------------
# Email transacional (Resend) — usado pelo módulo forms do toolkit
# -------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=joe@example.com
CONTACT_EMAIL_FROM="Site <no-reply@example.com>"

# -------------------------------------------------------------------------
# WhatsApp (público) — usado pelo módulo whatsapp do toolkit
# Formato: 5511999999999 (sem +, sem espaços, com DDI)
# -------------------------------------------------------------------------
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# -------------------------------------------------------------------------
# Analytics (público) — escolher UM provider
# -------------------------------------------------------------------------
# Vercel Analytics: ativar no painel da Vercel, sem env var.
# Plausible (opcional):
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT=https://plausible.io/js/script.js

# -------------------------------------------------------------------------
# EduCRM API (opcional — apenas sites de venda de cursos)
# -------------------------------------------------------------------------
# NEXT_PUBLIC_EDUCRM_API_BASE=https://crm.itm.pro.br
# EDUCRM_ESCOLA_SLUG=mte

# -------------------------------------------------------------------------
# Outros
# -------------------------------------------------------------------------
# NEXT_PUBLIC_GTM_ID=GTM-XXXX
